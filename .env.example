# Instagram MCP Proxy — Server-side OAuth credentials
#
# ONE Facebook App for the entire deployment. Each user authorizes this
# app to access their Instagram. Their per-user token is stored in their
# own Supabase schema. These secrets never leave the server.

FB_APP_ID=your_facebook_app_id
FB_APP_SECRET=your_facebook_app_secret

# OAuth redirect URI — must match what's configured in your Facebook App settings.
# Points to the n8n webhook which receives the OAuth callback automatically.
# No paste-back needed — the webhook exchanges the code and stores the token.
OAUTH_REDIRECT_URI=https://n8n.timothykosakoy.com/webhook/instagram-oauth-callback
